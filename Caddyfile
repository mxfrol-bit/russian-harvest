# Caddy configuration — Русский Урожай
# ======================================
# Works on: Railway (Nixpacks or Dockerfile), any Docker host, self-hosted.
# Caddy auto-configures HTTP/2, gzip, HTTPS (when applicable).

{
    # Railway and most platforms terminate TLS at the edge.
    auto_https off
    admin off
    servers {
        protocols h1 h2 h2c
    }
}

# Listen on $PORT (Railway provides it) or 8080 by default.
:{$PORT:8080} {
    # The site root. Dockerfile copies to /srv; nixpacks uses /app/site.
    # $SITE_ROOT env var lets us override without editing the file.
    root * {$SITE_ROOT:/srv}

    encode gzip zstd

    # Security headers (applied to all responses)
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(self), camera=(), microphone=()"
        -Server
    }

    # Pretty URLs: /catalog → /catalog.html
    @pretty {
        path /catalog /product /sale /about /how /contacts /account /offer /regulations /policy /dispute
    }
    rewrite @pretty {path}.html

    # Aggressive cache for static assets (1 year, immutable)
    @static path /assets/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Short cache for HTML (5 minutes, must revalidate)
    @html path *.html
    header @html Cache-Control "public, max-age=300, must-revalidate"

    # 404 fallback
    handle_errors {
        @404 expression {http.error.status_code} == 404
        rewrite @404 /404.html
        file_server
    }

    # Serve files: try exact path, then with .html suffix
    try_files {path} {path}.html
    file_server

    # Access log to stdout (Railway picks it up)
    log {
        output stdout
        format console
    }
}
