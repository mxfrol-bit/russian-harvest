# Caddy configuration — Русский Урожай
# ======================================
# Works on: Railway (Nixpacks or Dockerfile), any Docker host, self-hosted.
# Caddy auto-configures HTTP/2, gzip, HTTPS (when applicable).

{
    # Railway and most platforms terminate TLS at the edge.
    auto_https off
    admin off
    servers {
        protocols h1 h2 h2c
    }
}

# Listen on $PORT (Railway provides it) or 8080 by default.
:{$PORT:8080} {
    # The site root. Dockerfile copies to /srv; nixpacks uses /app/site.
    # $SITE_ROOT env var lets us override without editing the file.
    root * {$SITE_ROOT:/srv}

    encode gzip zstd

    # ====================================================================
    # SECURITY HEADERS — applied to all responses
    # ====================================================================
    header {
        # Запрещает встраивать сайт в iframe (защита от clickjacking)
        X-Frame-Options "SAMEORIGIN"

        # Браузер не угадывает MIME-тип (защита от MIME confusion attacks)
        X-Content-Type-Options "nosniff"

        # Referrer не передаётся на сторонние сайты с полным URL
        Referrer-Policy "strict-origin-when-cross-origin"

        # Запрещаем браузерные API для трекинга/скрытного шпионажа
        Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=()"

        # Принудительный HTTPS на год (важно после первого захода)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # Изоляция window'а от других origin (защита от Spectre/Meltdown)
        Cross-Origin-Opener-Policy "same-origin"

        # Защита от XS-Leaks через ресурсы
        Cross-Origin-Resource-Policy "same-site"

        # Content Security Policy — главная защита от XSS
        # Разрешаем:
        #  - default-src 'self' — только свои ресурсы
        #  - script-src 'self' + jsdelivr (для Supabase SDK) + 'unsafe-inline' (нужно для inline-handlers)
        #  - style-src 'self' + Google Fonts + 'unsafe-inline' (нужно для динамических стилей)
        #  - img-src — свои + русский урожай logo + data: для inline SVG
        #  - connect-src — Supabase API + свой домен
        #  - frame-ancestors 'self' — двойная защита от clickjacking
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://russian-harvest.ru https://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests"

        # Скрыть версию сервера
        -Server

        # Скрыть Caddy header
        -X-Powered-By
    }

    # Pretty URLs: /catalog → /catalog.html
    @pretty {
        path /catalog /product /sale /about /how /contacts /account /offer /regulations /policy /dispute
    }
    rewrite @pretty {path}.html

    # Cache static assets — revalidates frequently because we use ?v=BUILD_ID
    # cache-busting in <link>/<script> tags. Browsers will request a fresh URL
    # whenever the build ID changes, but the underlying file path stays cacheable.
    @static path /assets/*
    header @static Cache-Control "public, max-age=3600, must-revalidate"

    # Short cache for HTML (5 minutes, must revalidate)
    @html path *.html
    header @html Cache-Control "public, max-age=60, must-revalidate"

    # No cache for the root and folder paths so first hit is always fresh
    @root path / /index.html
    header @root Cache-Control "no-cache, must-revalidate"

    # 404 fallback
    handle_errors {
        @404 expression {http.error.status_code} == 404
        rewrite @404 /404.html
        file_server
    }

    # Serve files: try exact path, then with .html suffix
    try_files {path} {path}.html
    file_server

    # Access log to stdout (Railway picks it up)
    log {
        output stdout
        format console
    }
}
