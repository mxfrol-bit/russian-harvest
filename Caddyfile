# Caddy configuration — Русский Урожай (Railway)
# ================================================
# Caddy автоматически настраивает HTTPS, HTTP/2, gzip, brotli.
# Слушаем на порту, который даст Railway через переменную $PORT.

{
    # Global options
    admin off
    auto_https off
    servers {
        protocols h1 h2 h2c
    }
}

:{$PORT:8080} {
    root * /app/site
    encode gzip zstd

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(self), camera=(), microphone=()"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }

    # Pretty URLs: /catalog → /catalog.html
    @pretty {
        path /catalog /product /sale /about /how /contacts /account /offer /regulations /policy /dispute
    }
    rewrite @pretty {path}.html

    # Cache static assets aggressively
    @static {
        path /assets/*
    }
    header @static {
        Cache-Control "public, max-age=31536000, immutable"
    }

    # Cache HTML briefly
    @html {
        path *.html
    }
    header @html {
        Cache-Control "public, max-age=300, must-revalidate"
    }

    # 404 fallback
    handle_errors {
        @404 expression {http.error.status_code} == 404
        rewrite @404 /404.html
        file_server
    }

    # Serve files
    try_files {path} {path}.html
    file_server
    log {
        output stdout
        format console
    }
}
