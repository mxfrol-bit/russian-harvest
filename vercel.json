{
  "version": 2,
  "buildCommand": "python3 scripts/build.py",
  "outputDirectory": "site",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/catalog", "destination": "/catalog.html" },
    { "source": "/product/:id?", "destination": "/product.html" },
    { "source": "/sale", "destination": "/sale.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/how", "destination": "/how.html" },
    { "source": "/contacts", "destination": "/contacts.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/offer", "destination": "/offer.html" },
    { "source": "/regulations", "destination": "/regulations.html" },
    { "source": "/policy", "destination": "/policy.html" },
    { "source": "/dispute", "destination": "/dispute.html" }
  ],
  "headers": [
    {
      "source": "/assets/(css|js|img)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
